# Snowflake — scripts/snowflake_setup/run_snowflake_sql_pat.py (never commit PAT)
# SNOWFLAKE_PAT=
# SNOWFLAKE_SQL_API_HOST=
# SNOWFLAKE_ACCOUNT=
# Warehouse that must already exist for this API call:
# SNOWFLAKE_SQL_API_EXECUTION_WAREHOUSE=

# Snowflake objects for Fivetran setup
# SNOWFLAKE_FIVETRAN_PASSWORD=
# SNOWFLAKE_FIVETRAN_ROLE=
# SNOWFLAKE_FIVETRAN_USER=
# SNOWFLAKE_FIVETRAN_WAREHOUSE=
# SNOWFLAKE_DRIP_DATABASE=
# SNOWFLAKE_BRONZE_SCHEMA=
# Optional explicit host for downstream Fivetran destination setup:
# SNOWFLAKE_HOST=
# Render: python scripts/snowflake_setup/render_snowflake_fivetran_drip_sql.py -o /tmp/out.sql
# Or: python scripts/snowflake_setup/run_snowflake_sql_pat.py --render-from-env --sql-file scripts/snowflake_setup/snowflake_fivetran_drip_bronze_erp.sql
# MSSQL (local) - set after running scripts/setup-mssql.sh
# MSSQL_URL=mssql+pyodbc://sa:YOUR_PASSWORD@localhost:1433/master?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# Azure SQL (target for mssql_to_azure.py migration)
# AZURE_MSSQL_URL=mssql+pyodbc://USER:PASSWORD@SERVER.database.windows.net:1433/DATABASE?driver=ODBC+Driver+18+for+SQL+Server
# AZURE_MSSQL_SCHEMA=dbo  # Use dbo if app schema can't be created (default)

# Oracle (local) - set after running scripts/setup-oracle.sh
# ORACLE_URL=oracle+oracledb://app:AppPassword1@localhost:1521/?service_name=XEPDB1

# Available schemas for testing are public, erp_complex and prediction

# API (database-as-JSON) - Bearer token for simulated auth
# API_AUTH_TOKEN=your-secret-token
