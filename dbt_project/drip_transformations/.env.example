# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── Snowflake connection (required) ──────────────────────────────────────────
SNOWFLAKE_ACCOUNT=<account-identifier>       # e.g. xy12345.us-east-1
SNOWFLAKE_USER=<your-snowflake-username>
SNOWFLAKE_FIVETRAN_PASSWORD=<your-fivetran-password>
SNOWFLAKE_DATABASE=DRIP_DATA_INTELLIGENCE
SNOWFLAKE_WAREHOUSE=FIVETRAN_DRIP_WH

# -- dbt transformation service account (separate from Fivetran ingestion) ----
# Use these credentials in dbt Cloud -> Environments -> Deployment credentials
SNOWFLAKE_DBT_USER=DBT_DRIP_USER
SNOWFLAKE_DBT_ROLE=DBT_DRIP_ROLE
SNOWFLAKE_DBT_WAREHOUSE=DBT_DRIP_WH
SNOWFLAKE_DBT_PASSWORD=<your-dbt-password>

# ── dbt Cloud auth ───────────────────────────────────────────────────────────
# Option A (recommended for local): run `uvx dbt-mcp auth` — token stored in mcp.yml
# Option B (CI / shared): paste a service PAT below
# DBT_PAT=dbtu_...

# Your dbt Cloud numeric user ID — find it in your dbt Cloud profile URL
# e.g. https://rm291.us1.dbt.com/settings/profile → the number in the URL
# Required by the dbt MCP server.
# DBT_USER_ID=

# dbt Cloud tenant host (change if your account is on a different region/cell)
DBT_HOST=rm291.us1.dbt.com

# ── Unlock Discovery / SQL / Semantic Layer (optional) ───────────────────────
# Set these to the numeric IDs from your dbt Cloud environment URLs,
# then flip the DISABLE_* flags in start-dbt-mcp.sh to false.
# DBT_PROD_ENV_ID=
# DBT_DEV_ENV_ID=
