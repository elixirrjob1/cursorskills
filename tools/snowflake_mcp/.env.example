# Snowflake MCP Server — required environment variables
# Copy this file to ../../.env (repo root) and fill in your values.

# Snowflake account identifier (format: <orgname>-<accountname> or <locator>)
SNOWFLAKE_ACCOUNT=your_org-your_account

# Login user that the MCP server will connect as
SNOWFLAKE_USER=your_snowflake_user

# Password for the user above.
# The launcher re-exports this as SNOWFLAKE_PASSWORD for the MCP binary.
SNOWFLAKE_FIVETRAN_PASSWORD=your_password

# Default database context for the session
SNOWFLAKE_DATABASE=your_database

# Compute warehouse to use for queries
SNOWFLAKE_WAREHOUSE=your_warehouse
